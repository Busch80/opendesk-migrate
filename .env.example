# ====================================================================
# opendesk-migrate (odmig) — Environment Configuration Example
# Copy this to .env and fill in real values. NEVER commit .env
# ====================================================================

# Application
APP_ENV=development                  # development | production
APP_DEBUG=true                       # true | false
APP_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
APP_URL=http://localhost:8080
APP_NAME=opendesk-migrate

# Database
DATABASE_URL=postgresql+asyncpg://odmig:odmig@localhost:5432/odmig
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://localhost:6379/1

# Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_me_with_base64_44_chars_fernet_key=
SECRET_KEY=replace_me_with_random_64_chars_secret

# Storage Backend
STORAGE_BACKEND=local                # local | s3
STAGING_PATH=/staging
STAGING_MAX_GB=500
STAGING_RETENTION_DAYS=14

# M365 / Microsoft Graph (template — per-tenant overrides win)
M365_DEFAULT_TENANT_ID=
M365_AUTHORITY=https://login.microsoftonline.com

# Workers
CELERY_WORKER_CONCURRENCY_MAIL=4
CELERY_WORKER_CONCURRENCY_CAL_CONTACTS=2
CELERY_WORKER_CONCURRENCY_ONEDRIVE=4
CELERY_TASK_TIME_LIMIT=7200

# Rate limits (Graph API)
GRAPH_REQUESTS_PER_MINUTE=5000
GRAPH_BURST_SIZE=50
GRAPH_RETRY_MAX_ATTEMPTS=5

# OpenDesk defaults (per-tenant overrides win)
OX_DEFAULT_URL=
NC_DEFAULT_URL=

# Observability
PROMETHEUS_ENABLED=true
LOKI_URL=
SENTRY_DSN=

# i18n
DEFAULT_LOCALE=de
SUPPORTED_LOCALES=de,fr,it,en
